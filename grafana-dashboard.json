{
  "__inputs": [
    {
      "name": "DS_REGISTRY_STATS",
      "label": "Registry Stats",
      "description": "Infinity datasource configured with your registry-stats base URL",
      "type": "datasource",
      "pluginId": "yesoreyeram-infinity-datasource",
      "pluginName": "Infinity"
    }
  ],
  "title": "Registry Stats",
  "uid": "registry-stats",
  "description": "Docker Hub and GHCR image download tracking and registry analytics",
  "tags": ["registry", "docker", "ghcr", "downloads"],
  "timezone": "browser",
  "refresh": "1h",
  "time": { "from": "now-30d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "repo",
        "label": "Repository",
        "type": "query",
        "datasource": {
          "type": "yesoreyeram-infinity-datasource",
          "uid": "${DS_REGISTRY_STATS}"
        },
        "query": {
          "refId": "variable",
          "type": "json",
          "source": "url",
          "url": "http://registry-stats:9100/api/summary",
          "format": "table",
          "parser": "backend",
          "queryType": "infinity",
          "root_selector": "",
          "url_options": { "data": "", "method": "GET" },
          "columns": [
            { "selector": "name", "text": "name", "type": "string" }
          ],
          "infinityQuery": {
            "refId": "",
            "type": "json",
            "source": "url",
            "url": "http://registry-stats:9100/api/summary",
            "format": "table",
            "parser": "backend",
            "root_selector": "",
            "url_options": { "data": "", "method": "GET" },
            "columns": [
              { "selector": "name", "text": "name", "type": "string" }
            ],
            "filters": [],
            "data": ""
          }
        },
        "definition": "",
        "includeAll": true,
        "allValue": "",
        "current": { "text": ["All"], "value": ["$__all"] },
        "multi": true,
        "options": [],
        "refresh": 1,
        "regex": "",
        "sort": 1
      },
      {
        "name": "registry",
        "label": "Registry",
        "type": "query",
        "datasource": {
          "type": "yesoreyeram-infinity-datasource",
          "uid": "${DS_REGISTRY_STATS}"
        },
        "query": {
          "refId": "variable",
          "type": "json",
          "source": "url",
          "url": "http://registry-stats:9100/api/summary",
          "format": "table",
          "parser": "backend",
          "queryType": "infinity",
          "root_selector": "",
          "url_options": { "data": "", "method": "GET" },
          "columns": [
            { "selector": "registry", "text": "registry", "type": "string" }
          ],
          "infinityQuery": {
            "refId": "",
            "type": "json",
            "source": "url",
            "url": "http://registry-stats:9100/api/summary",
            "format": "table",
            "parser": "backend",
            "root_selector": "",
            "url_options": { "data": "", "method": "GET" },
            "columns": [
              { "selector": "registry", "text": "registry", "type": "string" }
            ],
            "filters": [],
            "data": ""
          }
        },
        "definition": "",
        "includeAll": true,
        "allValue": "",
        "current": { "text": "All", "value": "$__all" },
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": "",
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 10,
      "title": "Total Downloads",
      "description": "Sum of all downloads across all tracked packages and registries",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "${DS_REGISTRY_STATS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": 0 },
              { "color": "green", "value": 1000 },
              { "color": "yellow", "value": 100000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "/pull_count/", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      },
      "pluginVersion": "12.4.0",
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "/api/summary?repo=${repo}&registry=${registry}",
          "format": "table",
          "parser": "backend",
          "root_selector": "",
          "url_options": { "data": "", "method": "GET" },
          "columns": [
            { "selector": "pull_count", "text": "pull_count", "type": "number" }
          ]
        }
      ]
    },
    {
      "id": 1,
      "title": "Package Overview",
      "description": "Downloads per package merged across registries",
      "type": "table",
      "gridPos": { "h": 10, "w": 18, "x": 6, "y": 0 },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "${DS_REGISTRY_STATS}"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "name" },
            "properties": [{ "id": "displayName", "value": "Package" }]
          },
          {
            "matcher": { "id": "byName", "options": "pull_count (sum)" },
            "properties": [{ "id": "displayName", "value": "Total Downloads" }]
          },
          {
            "matcher": { "id": "byName", "options": "tag_count (sum)" },
            "properties": [{ "id": "displayName", "value": "Tags" }]
          },
          {
            "matcher": { "id": "byName", "options": "pull_count (sum)" },
            "properties": [
              { "id": "custom.footer.reducers", "value": ["sum"] }
            ]
          }
        ]
      },
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "sortBy": [{ "displayName": "Total Downloads", "desc": true }]
      },
      "pluginVersion": "12.4.0",
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "/api/summary?repo=${repo}&registry=${registry}",
          "format": "table",
          "parser": "backend",
          "root_selector": "",
          "url_options": { "data": "", "method": "GET" },
          "columns": [
            { "selector": "name", "text": "name", "type": "string" },
            { "selector": "pull_count", "text": "pull_count", "type": "number" },
            { "selector": "tag_count", "text": "tag_count", "type": "number" }
          ]
        }
      ],
      "transformations": [
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "name": { "aggregations": [], "operation": "groupby" },
              "pull_count": { "aggregations": ["sum"], "operation": "aggregate" },
              "tag_count": { "aggregations": ["sum"], "operation": "aggregate" }
            }
          }
        }
      ]
    },
    {
      "id": 11,
      "title": "Tracked Packages",
      "description": "Number of unique packages being tracked",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 5 },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "${DS_REGISTRY_STATS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": 0 }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["count"], "fields": "/name/", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      },
      "pluginVersion": "12.4.0",
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "/api/summary?repo=${repo}&registry=${registry}",
          "format": "table",
          "parser": "backend",
          "root_selector": "",
          "url_options": { "data": "", "method": "GET" },
          "columns": [
            { "selector": "name", "text": "name", "type": "string" }
          ]
        }
      ]
    },
    {
      "id": 2,
      "title": "Cumulative Downloads",
      "description": "Total download count over time per repo",
      "type": "timeseries",
      "gridPos": { "h": 13, "w": 12, "x": 0, "y": 10 },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "${DS_REGISTRY_STATS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [],
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "12.4.0",
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "/api/pulls?repo=${repo}&registry=${registry}",
          "format": "timeseries",
          "parser": "backend",
          "root_selector": "",
          "url_options": { "data": "", "method": "GET" },
          "columns": [
            { "selector": "timestamp", "text": "Timestamp", "type": "timestamp" },
            { "selector": "pull_count", "text": " ", "type": "number" },
            { "selector": "repo", "text": "Repo", "type": "string" }
          ]
        }
      ]
    },
    {
      "id": 3,
      "title": "Daily Download Delta",
      "description": "New downloads per day per repo — needs 2+ days of data",
      "type": "barchart",
      "gridPos": { "h": 13, "w": 12, "x": 12, "y": 10 },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "${DS_REGISTRY_STATS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "none"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [],
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" },
        "xTickLabelRotation": 0,
        "stacking": "normal",
        "barWidth": 0.1,
        "showValue": "never"
      },
      "pluginVersion": "12.4.0",
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "/api/pulls/daily?repo=${repo}&registry=${registry}",
          "format": "timeseries",
          "parser": "backend",
          "root_selector": "",
          "url_options": { "data": "", "method": "GET" },
          "columns": [
            { "selector": "timestamp", "text": "Timestamp", "type": "timestamp" },
            { "selector": "daily_pulls", "text": " ", "type": "number" },
            { "selector": "repo", "text": "Repo", "type": "string" }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 42,
  "version": 1
}
